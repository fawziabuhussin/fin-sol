generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ──────────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  emailVerified     DateTime?
  name              String?
  passwordHash      String?
  image             String?
  locale            String             @default("ar")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts          Account[]
  sessions          Session[]
  memberships       HouseholdMember[]
  dismissedInsights InsightDismissal[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tenancy ──────────────────────────────────────────────────

enum HouseholdRole {
  OWNER
  MEMBER
  VIEWER
}

model Household {
  id               String                @id @default(cuid())
  name             String
  currency         String                @default("ILS")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  members          HouseholdMember[]
  categories       Category[]
  paymentMethods   PaymentMethod[]
  incomeSources    IncomeSource[]
  transactions     Transaction[]
  buildContractors BuildContractor[]
  buildPayments    BuildPayment[]
  savingsPlans     SavingsPlan[]
  salarySlips      SalarySlip[]
  monthlySnapshots MonthlySnapshot[]
  insights         Insight[]
  buildProject     BuildProject?
  kerenProfile     KerenHishtalmutProfile?
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

// ─── Lookups ──────────────────────────────────────────────────

enum CategoryKind {
  EXPENSE
  INCOME
  SAVINGS
  BUILD
}

model Category {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  kind         CategoryKind  @default(EXPENSE)
  color        String?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
  @@index([householdId, kind])
}

model PaymentMethod {
  id            String         @id @default(cuid())
  householdId   String
  name          String
  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  buildPayments BuildPayment[]

  @@unique([householdId, name])
}

model IncomeSource {
  id           String        @id @default(cuid())
  householdId  String
  name         String
  isActive     Boolean       @default(true)
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([householdId, name])
}

// ─── Transactions ─────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
  SAVINGS_CONTRIBUTION
  BUILD_EXPENSE
}

model Transaction {
  id                String          @id @default(cuid())
  householdId       String
  date              DateTime        @db.Date
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("ILS")
  type              TransactionType
  categoryId        String?
  incomeSourceId    String?
  description       String?
  paymentMethodId   String?
  notes             String?
  isBuildExpense    Boolean         @default(false)
  buildContractorId String?
  buildPaymentId    String?         @unique
  savingsPlanId     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  incomeSource    IncomeSource?    @relation(fields: [incomeSourceId], references: [id])
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])
  buildContractor BuildContractor? @relation(fields: [buildContractorId], references: [id])
  buildPayment    BuildPayment?    @relation(fields: [buildPaymentId], references: [id])
  savingsPlan     SavingsPlan?     @relation(fields: [savingsPlanId], references: [id])

  @@index([householdId, date])
  @@index([householdId, type, date])
  @@index([householdId, categoryId])
  @@index([householdId, isBuildExpense])
}

// ─── Construction ─────────────────────────────────────────────

model BuildProject {
  id          String            @id @default(cuid())
  householdId String            @unique
  totalBudget Decimal           @db.Decimal(12, 2)
  notes       String?
  household   Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  contractors BuildContractor[]
}

enum BuildContractorStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  INACTIVE
}

model BuildContractor {
  id                    String                @id @default(cuid())
  householdId           String
  buildProjectId        String?
  name                  String
  profession            String?
  contractTotal         Decimal               @db.Decimal(12, 2)
  amountPaid            Decimal               @default(0) @db.Decimal(12, 2)
  remainingBalance      Decimal               @db.Decimal(12, 2)
  status                BuildContractorStatus @default(NOT_STARTED)
  reason                String?
  notes                 String?
  notesSecondary        String?
  isFullyPaid           Boolean               @default(false)
  downPayment           Decimal?              @db.Decimal(12, 2)
  totalInstallments     Int?
  installmentAmount     Decimal?              @db.Decimal(12, 2)
  installmentsCompleted Int                   @default(0)
  installmentsRemaining Int?
  monthsToCompletion    Int?
  firstPaymentDueDate   DateTime?             @db.Date
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  buildProject BuildProject? @relation(fields: [buildProjectId], references: [id])
  payments     BuildPayment[]
  transactions Transaction[]

  @@index([householdId, status])
}

model BuildPayment {
  id              String          @id @default(cuid())
  householdId     String
  contractorId    String
  paidAt          DateTime        @db.Date
  amount          Decimal         @db.Decimal(12, 2)
  paymentMethodId String?
  notes           String?
  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  contractor      BuildContractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  transaction     Transaction?

  @@index([householdId, paidAt])
  @@index([contractorId])
}

// ─── Savings ──────────────────────────────────────────────────

enum SavingsPlanType {
  JAMIYA
  PERSONAL
}

enum SavingsPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model SavingsPlan {
  id                  String            @id @default(cuid())
  householdId         String
  type                SavingsPlanType
  name                String
  monthlyContribution Decimal           @db.Decimal(12, 2)
  startDate           DateTime          @db.Date
  payoutDate          DateTime          @db.Date
  monthsCount         Int
  totalCommitment     Decimal           @db.Decimal(12, 2)
  paidToDate          Decimal           @default(0) @db.Decimal(12, 2)
  remaining           Decimal           @db.Decimal(12, 2)
  status              SavingsPlanStatus @default(ACTIVE)
  household           Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@index([householdId, status])
  @@index([householdId, payoutDate])
}

// ─── Salary ───────────────────────────────────────────────────

model SalarySlip {
  id              String           @id @default(cuid())
  householdId     String
  year            Int
  month           Int
  grossTotal      Decimal          @default(0) @db.Decimal(12, 2)
  deductionsTotal Decimal          @default(0) @db.Decimal(12, 2)
  netTotal        Decimal          @default(0) @db.Decimal(12, 2)
  employerName    String?
  slipDate        DateTime?        @db.Date
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  lineItems       SalaryLineItem[]

  @@unique([householdId, year, month])
}

enum SalaryLineKind {
  GROSS_COMPONENT
  DEDUCTION
  NET
}

model SalaryLineItem {
  id           String         @id @default(cuid())
  salarySlipId String
  code         String
  label        String
  labelHe      String?
  kind         SalaryLineKind
  amount       Decimal        @db.Decimal(12, 2)
  salarySlip   SalarySlip     @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@unique([salarySlipId, code])
}

model KerenHishtalmutProfile {
  id                   String    @id @default(cuid())
  householdId          String    @unique
  employerContribution Decimal?  @db.Decimal(12, 2)
  employeeContribution Decimal?  @db.Decimal(12, 2)
  currentBalance       Decimal   @default(0) @db.Decimal(12, 2)
  vestingEligibleDate  DateTime? @db.Date
  lastUpdatedAt        DateTime  @updatedAt
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

// ─── Aggregates ───────────────────────────────────────────────

model MonthlySnapshot {
  id                   String   @id @default(cuid())
  householdId          String
  year                 Int
  month                Int
  totalIncome          Decimal  @default(0) @db.Decimal(12, 2)
  dailyExpenses        Decimal  @default(0) @db.Decimal(12, 2)
  buildExpenses        Decimal  @default(0) @db.Decimal(12, 2)
  savingsContributions Decimal  @default(0) @db.Decimal(12, 2)
  netCashflow          Decimal  @default(0) @db.Decimal(12, 2)
  incomeBySource       Json     @default("{}")
  computedAt           DateTime @default(now())
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, year, month])
}

// ─── Smart insights ───────────────────────────────────────────

enum InsightType {
  LIQUIDITY_WARNING
  INVESTMENT_OPPORTUNITY
  BUDGET_ANOMALY
  TAX_SALARY_OPTIMIZATION
  BUILD_PAYMENT_DUE
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

model Insight {
  id          String             @id @default(cuid())
  householdId String
  type        InsightType
  severity    InsightSeverity    @default(INFO)
  title       String
  body        String
  actionLabel String?
  actionHref  String?
  metadata    Json?
  validFrom   DateTime           @default(now())
  validUntil  DateTime?
  household   Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  dismissals  InsightDismissal[]

  @@index([householdId, validUntil])
}

model InsightDismissal {
  id          String   @id @default(cuid())
  insightId   String
  userId      String
  dismissedAt DateTime @default(now())
  insight     Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([insightId, userId])
}
