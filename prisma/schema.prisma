generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  locale        String   @default("ar")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  transactions    Transaction[]
  savingsPlans    SavingsPlan[]
  savingsAssets   SavingsAsset[]
  salarySlips     SalarySlip[]
  employers       Employer[]
  categories      Category[]
  payees          Payee[]
  paymentMethods  PaymentMethod[]
  paymentPlans    ProjectPaymentPlan[]
  subscriptions   Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectKind {
  MASTER_BUILD
  BUILD_CONTRACTOR
  GENERAL
}

model Project {
  id              String        @id @default(cuid())
  userId          String
  parentProjectId String?
  kind            ProjectKind   @default(GENERAL)
  title           String
  profession      String?
  description     String?
  totalBudget     Decimal?      @db.Decimal(14, 2)
  targetDate      DateTime?     @db.Date
  status          ProjectStatus @default(PLANNED)
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Project?             @relation("ProjectTree", fields: [parentProjectId], references: [id], onDelete: SetNull)
  children      Project[]            @relation("ProjectTree")
  transactions  Transaction[]
  paymentPlans  ProjectPaymentPlan[]

  @@index([userId, status])
  @@index([userId, targetDate])
  @@index([userId, parentProjectId])
  @@index([userId, kind])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  SAVINGS_CONTRIBUTION
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  projectId       String?
  categoryId      String?
  payeeId         String?
  paymentMethodId String?
  salarySlipId    String?         @unique
  type            TransactionType
  amount          Decimal         @db.Decimal(14, 2)
  currency        String          @default("ILS")
  occurredAt      DateTime        @db.Date
  description     String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category       Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payee          Payee?               @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  paymentMethod  PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  salarySlip     SalarySlip?          @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)
  installment           ProjectInstallment?
  savingsEntry          SavingsEntry?
  savingsAssetEntry     SavingsAssetEntry?
  savingsAssetEntryFee  SavingsAssetEntry? @relation("SavingsAssetEntryFee")
  subscriptionPayment   SubscriptionPayment?

  @@index([userId, occurredAt])
  @@index([userId, type, occurredAt])
  @@index([userId, projectId])
  @@index([userId, categoryId])
}

enum CategoryKind {
  INCOME
  EXPENSE
  SAVINGS
}

model Category {
  id        String       @id @default(cuid())
  userId    String
  name      String
  kind      CategoryKind
  color     String?
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  subscriptions Subscription[]

  @@unique([userId, name, kind])
  @@index([userId, kind, isActive])
}

model Payee {
  id       String  @id @default(cuid())
  userId   String
  name     String
  isActive Boolean @default(true)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
}

model PaymentMethod {
  id       String  @id @default(cuid())
  userId   String
  name     String
  isActive Boolean @default(true)

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  paymentPlans  ProjectPaymentPlan[]
  subscriptions Subscription[]

  @@unique([userId, name])
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String
  title             String
  amount            Decimal  @db.Decimal(14, 2)
  billingDay        Int?
  categoryId        String?
  paymentMethodId   String?
  notes             String?
  isActive          Boolean  @default(true)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod?           @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  payments      SubscriptionPayment[]
  monthSkips    SubscriptionMonthSkip[]

  @@unique([userId, title])
  @@index([userId, isActive])
}

/** Hide a recurring subscription from a single calendar month without deleting it. */
model SubscriptionMonthSkip {
  id             String @id @default(cuid())
  subscriptionId String
  periodYear     Int
  periodMonth    Int

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, periodYear, periodMonth])
  @@index([subscriptionId])
}

model SubscriptionPayment {
  id             String    @id @default(cuid())
  subscriptionId String
  periodYear     Int
  periodMonth    Int
  amount         Decimal   @db.Decimal(14, 2)
  paid           Boolean   @default(false)
  paidAt         DateTime? @db.Date
  transactionId  String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([subscriptionId, periodYear, periodMonth])
  @@index([subscriptionId, paid])
}

enum SavingsPlanType {
  JAMIYA
  PERSONAL
  KUPOT
}

enum SavingsPlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

model SavingsPlan {
  id                  String            @id @default(cuid())
  userId              String
  employerId          String?
  title               String
  type                SavingsPlanType   @default(JAMIYA)
  monthlyContribution Decimal           @db.Decimal(14, 2)
  targetAmount        Decimal?          @db.Decimal(14, 2)
  payoutDate          DateTime?         @db.Date
  startDate           DateTime?         @db.Date
  durationMonths      Int?
  notes               String?
  status              SavingsPlanStatus @default(ACTIVE)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer Employer?      @relation(fields: [employerId], references: [id], onDelete: SetNull)
  entries  SavingsEntry[]

  @@index([userId, status])
  @@index([userId, payoutDate])
  @@index([userId, employerId])
}

model SavingsEntry {
  id            String    @id @default(cuid())
  planId        String
  periodYear    Int
  periodMonth   Int
  amount        Decimal   @db.Decimal(14, 2)
  paid          Boolean   @default(false)
  paidAt        DateTime? @db.Date
  isPayout      Boolean   @default(false)
  notes         String?
  transactionId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan        SavingsPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([planId, periodYear, periodMonth])
  @@index([planId, paid])
}

enum SavingsAssetKind {
  GOLD
  USD
  SILVER
  CRYPTO
  CUSTOM
}

model SavingsAsset {
  id            String           @id @default(cuid())
  userId        String
  kind          SavingsAssetKind
  title         String
  quantity      Decimal          @db.Decimal(14, 4)
  unitPrice     Decimal          @db.Decimal(14, 4)
  goldKarat     Int?
  unitLabel     String?
  priceCurrency String           @default("ILS")
  valueIls      Decimal          @db.Decimal(14, 2)
  notes         String?
  updatedAt     DateTime         @default(now()) @updatedAt
  createdAt     DateTime         @default(now())

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries SavingsAssetEntry[]

  @@unique([userId, title])
  @@index([userId, kind])
}

model SavingsAssetEntry {
  id               String   @id @default(cuid())
  assetId          String
  quantity         Decimal  @db.Decimal(14, 4)
  unitPrice        Decimal  @db.Decimal(14, 4)
  valueIls         Decimal  @db.Decimal(14, 2)
  purchasedAt      DateTime @db.Date
  notes            String?
  bankFeeIls       Decimal? @db.Decimal(14, 2)
  transactionId    String?  @unique
  feeTransactionId String?  @unique
  createdAt        DateTime @default(now())

  asset          SavingsAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  feeTransaction Transaction? @relation("SavingsAssetEntryFee", fields: [feeTransactionId], references: [id], onDelete: SetNull)

  @@index([assetId, purchasedAt])
}

model Employer {
  id          String  @id @default(cuid())
  userId      String
  name        String
  role        String?
  color       String?
  baseGross   Decimal @default(0) @db.Decimal(14, 2)
  baseNet     Decimal @default(0) @db.Decimal(14, 2)
  baseTax     Decimal @default(0) @db.Decimal(14, 2)
  basePension Decimal @default(0) @db.Decimal(14, 2)
  baseKeren   Decimal @default(0) @db.Decimal(14, 2)
  baseFees    Decimal @default(0) @db.Decimal(14, 2)
  baseBonus   Decimal @default(0) @db.Decimal(14, 2)
  /** Default מסים/פנסיה breakdown for new months */
  baseSlipBreakdown Json?
  startDate   DateTime? @db.Date
  active      Boolean @default(true)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  salarySlips  SalarySlip[]
  savingsPlans SavingsPlan[]

  @@unique([userId, name])
  @@index([userId])
}

model SalarySlip {
  id              String   @id @default(cuid())
  userId          String
  employerId      String
  periodYear      Int
  periodMonth     Int
  worked          Boolean  @default(true)
  gross           Decimal  @default(0) @db.Decimal(14, 2)
  net             Decimal  @default(0) @db.Decimal(14, 2)
  tax             Decimal  @default(0) @db.Decimal(14, 2)
  pension         Decimal  @default(0) @db.Decimal(14, 2)
  kerenHishtalmut Decimal  @default(0) @db.Decimal(14, 2)
  fees            Decimal  @default(0) @db.Decimal(14, 2)
  bonus           Decimal  @default(0) @db.Decimal(14, 2)
  paid            Boolean  @default(false)
  paidAt          DateTime? @db.Date
  slipFileUrl     String?
  /** Pension (גמל), taxes (מסים), keren — parsed from תלוש PDF */
  slipBreakdown   Json?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employer    Employer     @relation(fields: [employerId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@unique([userId, employerId, periodYear, periodMonth])
  @@index([userId, periodYear, periodMonth])
}

enum PaymentPlanMode {
  FULL
  INSTALLMENTS
}

enum InstallmentStatus {
  PENDING
  PAID
  SKIPPED
}

model ProjectPaymentPlan {
  id                 String          @id @default(cuid())
  userId             String
  projectId          String
  title              String?
  mode               PaymentPlanMode
  totalAmount        Decimal         @db.Decimal(14, 2)
  installmentCount   Int?
  firstPaymentAmount Decimal?        @db.Decimal(14, 2)
  recurringAmount    Decimal?        @db.Decimal(14, 2)
  payeeName          String?
  startDate          DateTime?       @db.Date
  paymentMethodId    String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  installments  ProjectInstallment[]

  @@index([userId, projectId])
}

model ProjectInstallment {
  id            String            @id @default(cuid())
  planId        String
  sequence      Int
  label         String?
  dueDate       DateTime          @db.Date
  amount        Decimal           @db.Decimal(14, 2)
  status        InstallmentStatus @default(PENDING)
  notes         String?
  transactionId String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  plan        ProjectPaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  transaction Transaction?       @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([planId, sequence])
  @@index([planId, status])
  @@index([dueDate, status])
}
